<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_color"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Title -->
        <TextView
            android:id="@+id/tvAppTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Smart Finance AI"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Main Balance Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardBalance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/primary"
            app:layout_constraintTop_toBottomOf="@id/tvAppTitle">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TOTAL SALDO BERSIH"
                    android:textColor="#CCFBF1"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05" />

                <TextView
                    android:id="@+id/tvTotalBalance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Rp 0"
                    android:textColor="@color/surface_white"
                    android:textSize="30sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Income & Expense Row -->
        <LinearLayout
            android:id="@+id/layoutIncomeExpense"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            android:baselineAligned="false"
            android:weightSum="2"
            app:layout_constraintTop_toBottomOf="@id/cardBalance">

            <!-- Income Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🟢 Pemasukan"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />
                        
                    <TextView
                        android:id="@+id/tvIncomeSummary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Rp 0"
                        android:textColor="@color/income_green"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Expense Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔴 Pengeluaran"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />
                        
                    <TextView
                        android:id="@+id/tvExpenseSummary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Rp 0"
                        android:textColor="@color/expense_red"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Header Laporan & Grafik -->
        <LinearLayout
            android:id="@+id/headerChart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/layoutIncomeExpense">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Grafik Laporan Keuangan"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_secondary" />
            <TextView
                android:id="@+id/btnDetailLaporan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Detail Laporan"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/primary" />
        </LinearLayout>

        <!-- Tempat Grafik dari Code -->
        <FrameLayout
            android:id="@+id/chartContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/headerChart" />

        <!-- Header Pengeluaran Teratas -->
        <LinearLayout
            android:id="@+id/headerTopExpense"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/chartContainer">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Pengeluaran Teratas"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_secondary" />
            <TextView
                android:id="@+id/btnLihatAnalisis"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lihat Analisis"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/primary" />
        </LinearLayout>

        <!-- Card Pengeluaran Teratas & Filter -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardTopExpense"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/headerTopExpense">
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:id="@+id/filterTabsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp"
                    android:padding="4dp">
                    
                    <TextView
                        android:id="@+id/btnTabWeek"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Minggu"
                        android:textSize="12.5sp" />

                    <TextView
                        android:id="@+id/btnTabMonth"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Bulan"
                        android:textSize="12.5sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/topExpenseContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Header Transaksi Terkini -->
        <LinearLayout
            android:id="@+id/headerRecentTx"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/cardTopExpense">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Transaksi Terkini"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_secondary" />
            <TextView
                android:id="@+id/btnLihatSemua"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lihat Semua"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/primary" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/recentTxContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/headerRecentTx" />

        <TextView
            android:id="@+id/tvDashboardReport"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:text=""
            app:layout_constraintTop_toBottomOf="@id/recentTxContainer"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
