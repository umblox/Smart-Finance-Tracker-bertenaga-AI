<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pengaturan Sistem"
            android:textColor="#1E293B"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="KECERDASAN &amp; SERVER"
            android:textColor="#0D9488"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/menuApiConfig"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="14dp"
            app:cardElevation="1dp">
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp" android:text="🔑 Konfigurasi Mesin AI" android:textColor="#334155" android:textSize="15sp" android:textStyle="bold" app:drawableEndCompat="@android:drawable/ic_menu_edit" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/menuFirebaseJson"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="14dp"
            app:cardElevation="1dp">
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp" android:text="☁️ Upload Google Services JSON" android:textColor="#334155" android:textSize="15sp" android:textStyle="bold" app:drawableEndCompat="@android:drawable/ic_menu_upload" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/menuExpertMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="#1E293B"
            app:cardCornerRadius="14dp"
            app:cardElevation="2dp">
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp" android:text="🧠 Expert Mode (Prompt Override)" android:textColor="#38BDF8" android:textSize="15sp" android:textStyle="bold" app:drawableEndCompat="@android:drawable/ic_menu_manage" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DATA &amp; KEAMANAN"
            android:textColor="#0D9488"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/menuManageCategories"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="14dp"
            app:cardElevation="1dp">
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp" android:text="🗂️ Kelola Master Kategori" android:textColor="#334155" android:textSize="15sp" android:textStyle="bold" app:drawableEndCompat="@android:drawable/ic_menu_sort_by_size" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/menuRecurringTx"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="14dp"
            app:cardElevation="1dp">
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp" android:text="⏳ Transaksi Berkala / Terjadwal" android:textColor="#334155" android:textSize="15sp" android:textStyle="bold" app:drawableEndCompat="@android:drawable/ic_menu_today" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/menuExportCsv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="14dp"
            app:cardElevation="1dp">
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp" android:text="📥 Backup &amp; Export Data (CSV)" android:textColor="#334155" android:textSize="15sp" android:textStyle="bold" app:drawableEndCompat="@android:drawable/ic_menu_save" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/menuBiometric"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="14dp"
            app:cardElevation="1dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="16dp" android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="🔒 Kunci Keamanan Biometrik" android:textColor="#334155" android:textSize="15sp" android:textStyle="bold" />
                <com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/switchBiometric" android:layout_width="wrap_content" android:layout_height="wrap_content" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
